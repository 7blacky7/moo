# Python
__pycache__/
*.pyc
.venv/
dist/
*.egg-info/
.mypy_cache/

# Rust / C Build-Artefakte
compiler/target/
*.o
*.bin
*.a
*.so
*.dylib

# LLVM IR
*.ll

# Compiler-Test-Artefakte
compiler/runtime/check_size*
compiler/runtime/test_runtime*
compiler/runtime/test_3d

# Kompilierte moo-Beispiele — Whitelist-Ansatz:
# beispiele/<name> neben beispiele/<name>.moo ist eine Binary
# Alle Dateien im beispiele-Baum ignorieren, nur bekannte Source-Typen tracken
beispiele/**
!beispiele/
!beispiele/**/
!beispiele/**/*.moo
!beispiele/**/*.md
!beispiele/**/*.html
!beispiele/**/*.py
!beispiele/**/*.ld
!beispiele/**/*.json
!beispiele/**/*.txt
!beispiele/**/*.css
!beispiele/**/*.js
!beispiele/**/*.ts
!beispiele/**/*.sh
!beispiele/**/*.png
!beispiele/**/*.jpg
!beispiele/**/*.bmp
!beispiele/**/*.gif
!beispiele/**/*.svg
!beispiele/**/*.ogg
!beispiele/**/*.wav
!beispiele/**/*.ttf
!beispiele/**/*.gitkeep

# Plan-008 A4: generierte Game-Test-Artefakte (Screenshots/GIFs/Logs/JSON-Report).
# Der Runner (scripts/game-test-runner.sh) erzeugt sie zur Laufzeit; nicht versionieren.
/beispiele/snapshots/game-test/
!beispiele/**/README*

# Grosse Asset-Archive explizit ausschliessen
beispiele/assets/sprites/*.zip
beispiele/assets/sprites/kenney_td/
beispiele/assets/sprites/kenney_td_kit/

# Test-Screenshots (regenerierbar, 1.9MB pro BMP)
beispiele/test_screenshots/

# Lokale Beispiel-/Smoke-Arbeitsflächen: funktionieren, aber nicht automatisch versionieren.
# Bei Bedarf bewusst auskommentieren und gezielt committen.
/beispiele/domain/system/kernel_test_builtins.moo
/beispiele/ui_snapshot_smoke.moo
/beispiele/city_builder/reconnect-session.sh
/beispiele/snapshots/

# Compiler-Beispiele (nur Source)
compiler/beispiele/**
!compiler/beispiele/
!compiler/beispiele/**/*.moo
!compiler/beispiele/**/*.expected

# Compiler-Test-Binaries im compiler/ Root
compiler/grafik_demo
compiler/pong
compiler/runtime/test_3d.c

# Root-Test-Artefakte (nur Source behalten).
# Siehe spec/repo_cleanup_phase_b.md — in Phase B wandern die .moo-Quellen
# nach compiler/tests/ bzw. scratch/; die kompilierten Binaries hier bleiben
# dauerhaft gitignored.
/test_neu
/test_oop
/test_mix
/test_en
/test_alle
/test_native
/test_vollst*
/example
/beispiel
/adventure_save.json
/beispiele/test_sprite.bmp

# Lokale Root-Testflächen / manuelle Leak-Smokes.
# Bei Bedarf bewusst auskommentieren und als Regression integrieren.
/tests/test_memory_leaks.moo
/tests/verify_leaks.py

# Lokale Beispiel-Binaries
/voxel_sandbox

# Scratch-/Ad-hoc-Verzeichnis: Source-Dateien werden getrackt,
# kompilierte Artefakte nicht (siehe scratch/README.md).
/scratch/**/*.ll
/scratch/**/*.o
/scratch/**/*.bin

# Save-Files
*.save

# Editor-Artefakte
