# Const-Folding Test — Compile-Zeit Berechnung
setze pi auf 3.14159
setze radius auf 10.0
# Diese werden zur Compile-Zeit berechnet (Number op Number):
setze umfang auf 2 * 3.14159 * 10
zeige umfang

# String-Concat zur Compile-Zeit:
setze gruss auf "Hallo" + " " + "Welt"
zeige gruss

# Vergleich zur Compile-Zeit:
zeige 5 > 3
zeige 10 == 10
