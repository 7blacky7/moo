# Erster nativer moo-Test!

setze x auf 42
setze y auf 8
setze ergebnis auf x + y
zeige ergebnis

setze potenz auf 2 ** 10
zeige potenz

# Bedingung
wenn ergebnis > 40:
    zeige 1
sonst:
    zeige 0

# Schleife
setze i auf 0
solange i < 5:
    zeige i
    i += 1

# Funktion
funktion quadrat(n):
    gib_zurück n * n

zeige quadrat(7)
zeige quadrat(12)
