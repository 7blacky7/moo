# Test: Lambdas und Higher-Order Functions
setze addiere auf (a, b) => a + b
zeige addiere(3, 4)

setze verdopple auf (x) => x * 2
zeige verdopple(5)

# Lambda als Argument
setze zahlen auf [1, 2, 3, 4, 5]
setze ergebnis auf zahlen.filter((x) => x > 2)
zeige ergebnis

setze quadrate auf zahlen.map((x) => x * x)
zeige quadrate

# Verschachtelte Lambdas
setze liste auf [10, 3, 7, 1, 9]
setze sortiert auf liste.sortieren()
zeige sortiert
