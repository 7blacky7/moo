# ============================================================
# ki_multimodal_audio.moos — KI-MULTI-V3b: Audio-Adapter
#
# Sinus-Kommando -> |STFT|-Spektrogramm -> Conv-Encoder (V2) ->
# Projektion -> Praefix-Slot im Mini-LLM -> Caption.
# Design: docs/kip/V3-multimodal-fusion.md (§3, §5, §7).
# Architektur-Muster: beispiele/ki_multimodal_vision.moos (V3a).
#
# Faktoren (3): BAND (tief|mittel|hoch) x DAUER (kurz|lang)
#               x MUSTER (konstant|pulsierend) = 12 Klassen.
# Stufen: A  Encoder contrastive (kompositionale Anker band+dauer+muster)
#         B0 Mini-LLM KONDITIONAL vortrainieren: Lehr-Slots in 3
#            disjunkten Subraeumen + Rauschen (V3a-Learnings)
#         B  NUR die Projektion trainieren (CE + MSE-Anker, LR 0.02)
# Gates:  A   Retrieval accuracy@1 >= 0.95 (frische Jitter, 10 Klassen)
#         1a  Caption-Accuracy >= 0.9 auf Jitter-Holdout (Greedy, exakt)
#         1b  Caption-Accuracy >= 0.9 auf Kombi-Holdout (ungesehene
#             Faktor-Kombis — beweist Komposition)
#         2   FD-Gradcheck der Projektion (4 Koordinaten)
#         3   Checkpoint-Roundtrip: Save -> Load -> Loss bit-identisch
#
# Headless: moo-compiler run beispiele/ki_multimodal_audio.moos
# Endet mit SELFTEST_RESULT: PASS/FAIL. Deterministisch (feste Seeds).
# ============================================================

konstante SR auf 8000
konstante N auf 1056
konstante FRAMES auf 32
konstante BINS auf 33
konstante DIM_ENC auf 32
konstante DIM auf 48
konstante KOEPFE auf 4
konstante T_TEXT auf 30
konstante JITTER_TRAIN auf 6
konstante JITTER_TEST auf 2
konstante JITTER_COMBO auf 6
konstante EPS_FD auf 0.02
konstante PI auf 3.14159265358979
konstante TWO_PI auf 6.28318530717959

setze BAENDER auf ["tiefer", "mittlerer", "hoher"]
setze DAUERN auf ["kurz", "lang"]
setze MUSTER auf ["konstant", "pulsierend"]
setze FREQS auf [275, 800, 1800]

# Kombi-Holdout: diese (band, dauer, muster)-Kombis NIE im Training.
# tief+lang+pulsierend (knr 3) und hoch+kurz+konstant (knr 8).
funktion ist_holdout(b, d, m):
    wenn b == 0 und d == 1 und m == 1:
        gib_zurück wahr
    wenn b == 2 und d == 0 und m == 0:
        gib_zurück wahr
    gib_zurück falsch

# ------------------------------------------------------------
# 0. Zustand: LCG + alle Schichten in einem Dict (M)
# ------------------------------------------------------------
setze G auf {}
G["rng"] = 7
funktion rng():
    G["rng"] = (G["rng"] * 75 + 74) % 65537
    gib_zurück G["rng"]

setze M auf {}

# ------------------------------------------------------------
# 1. Toy-Signale: Sinus mit Band/Dauer/Muster + Jitter -> |STFT|
# ------------------------------------------------------------
funktion my_cos(x):
    setze v auf x
    solange v > PI:
        setze v auf v - TWO_PI
    solange v < 0 - PI:
        setze v auf v + TWO_PI
    setze x2 auf v * v
    gib_zurück 1 - x2 / 2 + x2 * x2 / 24 - x2 * x2 * x2 / 720

funktion my_sin(x):
    gib_zurück my_cos(x - 1.5707963267948966)

# Rendert ein Sample: flache |STFT|-Liste (FRAMES*BINS = 1056 Werte).
funktion sample_merkmale(b, d, m):
    setze freq auf FREQS[b] * (1 + (rng() % 9 - 4) * 0.01)
    setze amp auf 0.5 + (rng() % 5) * 0.05
    setze phase auf (rng() % 100) * 0.0628
    setze aktiv auf N
    wenn d == 0:
        setze aktiv auf boden(N / 2)
    setze schrittw auf TWO_PI * freq / SR
    setze modw auf TWO_PI * 45 / SR
    setze samples auf []
    setze w auf phase
    setze wm auf 0
    setze i auf 0
    solange i < N:
        setze a auf 0
        wenn i < aktiv:
            setze a auf amp
            wenn m == 1:
                setze a auf amp * (0.25 + 0.375 * (1 + my_cos(wm)))
        samples.hinzufügen(my_sin(w) * a)
        setze w auf w + schrittw
        wenn w > PI:
            setze w auf w - TWO_PI
        setze wm auf wm + modw
        wenn wm > PI:
            setze wm auf wm - TWO_PI
        setze i auf i + 1
    setze t auf tensor_aus_liste(samples)
    gib_zurück spektrogramm(t, 64, 32).zu_liste()

# ------------------------------------------------------------
# 2. Captions + Zeichen-Vokabular
# ------------------------------------------------------------
funktion caption(b, d, m):
    setze c auf BAENDER[b] + " ton " + DAUERN[d] + " " + MUSTER[m]
    solange länge(c) < T_TEXT:
        setze c auf c + "."
    gib_zurück c

setze korpus auf "."
setze b auf 0
solange b < 3:
    setze d auf 0
    solange d < 2:
        setze m auf 0
        solange m < 2:
            setze korpus auf korpus + caption(b, d, m)
            setze m auf m + 1
        setze d auf d + 1
    setze b auf b + 1
setze tok auf text_tokenizer(korpus)
setze vokab auf tok["vokab"]
setze id_zu_zeichen auf tok["id_zu_zeichen"]
setze z2i auf {}
setze k auf 0
solange k < vokab:
    z2i[id_zu_zeichen[k]] = k
    setze k auf k + 1

# knr = b*4 + d*2 + m; Rueckweg:
funktion knr_b(knr):
    gib_zurück boden(knr / 4)
funktion knr_d(knr):
    gib_zurück boden((knr % 4) / 2)
funktion knr_m(knr):
    gib_zurück knr % 2

funktion caption_ids(knr):
    setze c auf caption(knr_b(knr), knr_d(knr), knr_m(knr))
    setze ids auf []
    setze i auf 0
    solange i < T_TEXT:
        ids.hinzufügen(z2i[c[i]])
        setze i auf i + 1
    gib_zurück ids

funktion ids_gleich(a, bb):
    wenn länge(a) != länge(bb):
        gib_zurück falsch
    setze i auf 0
    solange i < länge(a):
        wenn a[i] != bb[i]:
            gib_zurück falsch
        setze i auf i + 1
    gib_zurück wahr

funktion ids_zu_text(ids):
    setze t auf ""
    setze i auf 0
    solange i < länge(ids):
        setze t auf t + id_zu_zeichen[ids[i]]
        setze i auf i + 1
    gib_zurück t

# ------------------------------------------------------------
# 3. Datensatz erzeugen (deterministisch) + Pruefwert-Log
# ------------------------------------------------------------
zeige "Erzeuge Audio-Toy-Datensatz ..."
setze train_px auf []
setze train_kl auf []
setze jit_px auf []
setze jit_kl auf []
setze combo_px auf []
setze combo_kl auf []
setze pruef auf 0
setze b auf 0
solange b < 3:
    setze d auf 0
    solange d < 2:
        setze m auf 0
        solange m < 2:
            setze knr auf b * 4 + d * 2 + m
            wenn ist_holdout(b, d, m):
                setze j auf 0
                solange j < JITTER_COMBO:
                    setze p auf sample_merkmale(b, d, m)
                    combo_px.hinzufügen(p)
                    combo_kl.hinzufügen(knr)
                    setze pruef auf (pruef + p[rng() % 1056] * 1000 + knr) % 987654321
                    setze j auf j + 1
            sonst:
                setze j auf 0
                solange j < JITTER_TRAIN:
                    setze p auf sample_merkmale(b, d, m)
                    train_px.hinzufügen(p)
                    train_kl.hinzufügen(knr)
                    setze pruef auf (pruef + p[rng() % 1056] * 1000 + knr) % 987654321
                    setze j auf j + 1
                setze j auf 0
                solange j < JITTER_TEST:
                    setze p auf sample_merkmale(b, d, m)
                    jit_px.hinzufügen(p)
                    jit_kl.hinzufügen(knr)
                    setze pruef auf (pruef + p[rng() % 1056] * 1000 + knr) % 987654321
                    setze j auf j + 1
            setze m auf m + 1
        setze d auf d + 1
    setze b auf b + 1
zeige "V3B-DATEN train=" + text(länge(train_px)) + " jitter-holdout=" + text(länge(jit_px)) + " kombi-holdout=" + text(länge(combo_px)) + " pruefwert=" + text(pruef)

# ------------------------------------------------------------
# 4. Schichten (alle Seeds fest) — Zwei-Pfad-Encoder:
#    Band-Pfad zeitinvariant (global max-pool), Zeit-Pfad grob-raeumlich
# ------------------------------------------------------------
M["f1"] = schicht_faltung(1, 8, 3, 1, 1, "relu", 21)
M["p1"] = schicht_pooling("max", 2, 2)
M["f2"] = schicht_faltung(8, 16, 3, 1, 1, "relu", 22)
M["p2"] = schicht_pooling("max", 2, 2)
M["pg"] = schicht_pooling("max", 8, 8)
M["fl"] = schicht_flach()
M["ed"] = schicht_dicht(16, 12, "tanh", 23)
# Zeit-Pfad: flacher Conv-Zweig, frueh grob gepoolt (Dauer/Muster, kaum Band-Detail)
M["f1o"] = schicht_faltung(1, 4, 3, 1, 1, "relu", 26)
M["p1o"] = schicht_pooling("mittel", 2, 2)
M["po"] = schicht_pooling("mittel", 4, 4)
M["flo"] = schicht_flach()
M["edo"] = schicht_dicht(4 * 4 * 4, 10, "tanh", 27)
M["edm"] = schicht_dicht(4 * 4 * 4, 10, "tanh", 28)
M["emb"] = schicht_embedding(vokab, DIM, 31)
M["pos"] = schicht_position(1 + T_TEXT, DIM, "gelernt", 32)
M["ln1"] = schicht_layernorm(DIM)
M["att"] = schicht_attention(DIM, KOEPFE, 33)
M["ln2"] = schicht_layernorm(DIM)
M["ff1"] = schicht_dicht(DIM, 128, "gelu", 34)
M["ff2"] = schicht_dicht(128, DIM, "keine", 35)
M["lnf"] = schicht_layernorm(DIM)
M["kopf"] = schicht_dicht(DIM, vokab, "keine", 36)
M["proj"] = schicht_dicht(DIM_ENC, DIM, "keine", 41)

funktion enc_schichten():
    gib_zurück [M["f1"], M["p1"], M["f2"], M["p2"], M["pg"], M["fl"], M["ed"], M["f1o"], M["p1o"], M["po"], M["flo"], M["edo"], M["edm"]]
funktion band_schichten():
    gib_zurück [M["f1"], M["p1"], M["f2"], M["p2"], M["pg"], M["fl"], M["ed"]]
funktion dauer_schichten():
    gib_zurück [M["f1o"], M["p1o"], M["po"], M["flo"], M["edo"]]
funktion muster_schichten():
    gib_zurück [M["f1o"], M["p1o"], M["po"], M["flo"], M["edm"]]
funktion llm_schichten():
    gib_zurück [M["emb"], M["pos"], M["ln1"], M["att"], M["ln2"], M["ff1"], M["ff2"], M["lnf"], M["kopf"]]

# Konstante 0/1-Subraum-Injektionen: band dims 0..11, dauer 12..21, muster 22..31
autograd_aus()
setze EB auf tensor_nullen([12, DIM_ENC])
setze i auf 0
solange i < 12:
    EB.wert_setzen([i, i], 1)
    setze i auf i + 1
setze ED auf tensor_nullen([10, DIM_ENC])
setze i auf 0
solange i < 10:
    ED.wert_setzen([i, 12 + i], 1)
    setze i auf i + 1
setze EM auf tensor_nullen([10, DIM_ENC])
setze i auf 0
solange i < 10:
    EM.wert_setzen([i, 22 + i], 1)
    setze i auf i + 1
autograd_an()

funktion encoder_batch(merkmal_listen):
    setze x auf tensor_aus_liste(merkmal_listen)
    setze x auf x.umformen([länge(merkmal_listen), FRAMES, BINS, 1])
    # Drei Koepfe schreiben via Injektions-matmul in DISJUNKTE Subraeume —
    # erzwingt getrennte Faktor-Repraesentation (Kompositions-Fix nach 7/8-Plateau)
    gib_zurück vorwaerts(band_schichten(), x).matmul(EB) + vorwaerts(dauer_schichten(), x).matmul(ED) + vorwaerts(muster_schichten(), x).matmul(EM)

funktion llm_kern(x):
    setze x auf vorwaerts([M["pos"]], x)
    setze x auf x + vorwaerts([M["ln1"], M["att"]], x)
    setze x auf x + vorwaerts([M["ln2"], M["ff1"], M["ff2"]], x)
    gib_zurück vorwaerts([M["lnf"], M["kopf"]], x)

# Praefix-Injection (Design §3.3): x = verketten(e_inj, emb(text))
funktion mm_logits(e_inj, ids):
    setze x auf e_inj
    wenn länge(ids) > 0:
        setze e_txt auf vorwaerts([M["emb"]], tensor_aus_liste(ids))
        setze x auf e_inj.verketten(e_txt)
    gib_zurück llm_kern(x)

funktion seq_loss(e_inj, ids):
    setze logits auf mm_logits(e_inj, ids)
    setze ziele auf []
    setze maske auf []
    setze i auf 0
    solange i < länge(ids):
        ziele.hinzufügen(ids[i])
        maske.hinzufügen(1)
        setze i auf i + 1
    ziele.hinzufügen(0)
    maske.hinzufügen(0)
    gib_zurück kreuzentropie(logits, tensor_aus_liste(ziele), tensor_aus_liste(maske))

funktion argmax(liste):
    setze best auf 0
    setze i auf 1
    solange i < länge(liste):
        wenn liste[i] > liste[best]:
            setze best auf i
        setze i auf i + 1
    gib_zurück best

funktion grads_loeschen(params):
    für p in params:
        p.gradient_loeschen()

# ------------------------------------------------------------
# 5. STUFE A: Encoder contrastive (kompositionale Anker, 3 Faktoren)
# ------------------------------------------------------------
zeige "Stufe A: Encoder Anker-Regression (450 Schritte) ..."
# Anker leben in DENSELBEN disjunkten Subraeumen wie die Encoder-Koepfe.
# Skala 0.7: sicher im tanh-Wertebereich (Stufe A = Anker-Regression).
autograd_aus()
setze band_proto auf tensor_nullen([3, DIM_ENC])
setze bpz auf tensor_zufall([3, DIM_ENC], 55)
setze i auf 0
solange i < 3:
    setze j auf 0
    solange j < 12:
        band_proto.wert_setzen([i, j], bpz.wert([i, j]) * 0.7)
        setze j auf j + 1
    setze i auf i + 1
setze dauer_proto auf tensor_nullen([2, DIM_ENC])
setze dpz auf tensor_zufall([2, DIM_ENC], 56)
setze i auf 0
solange i < 2:
    setze j auf 12
    solange j < 22:
        dauer_proto.wert_setzen([i, j], dpz.wert([i, j]) * 0.7)
        setze j auf j + 1
    setze i auf i + 1
setze muster_proto auf tensor_nullen([2, DIM_ENC])
setze mpz auf tensor_zufall([2, DIM_ENC], 57)
setze i auf 0
solange i < 2:
    setze j auf 22
    solange j < 32:
        muster_proto.wert_setzen([i, j], mpz.wert([i, j]) * 0.7)
        setze j auf j + 1
    setze i auf i + 1
autograd_an()

funktion proto_zeile(knr):
    gib_zurück band_proto.zeilen(knr_b(knr), knr_b(knr) + 1) + dauer_proto.zeilen(knr_d(knr), knr_d(knr) + 1) + muster_proto.zeilen(knr_m(knr), knr_m(knr) + 1)

funktion proto_stapel(klassen):
    setze p auf proto_zeile(klassen[0])
    setze i auf 1
    solange i < länge(klassen):
        setze p auf p.verketten(proto_zeile(klassen[i]))
        setze i auf i + 1
    gib_zurück p

setze params_enc auf parameter(enc_schichten())
setze opt_a auf optimierer_sgd(params_enc, 0.05, 0.9)
setze s auf 0
solange s < 450:
    setze bx auf []
    setze bk auf []
    setze i auf 0
    solange i < 10:
        setze idx auf i * JITTER_TRAIN + s % JITTER_TRAIN
        bx.hinzufügen(train_px[idx])
        bk.hinzufügen(train_kl[idx])
        setze i auf i + 1
    setze enc auf encoder_batch(bx)
    # Anker-Regression: Subraeume disjunkt -> EIN MSE ueber den vollen Vektor
    setze dva auf enc - proto_stapel(bk)
    setze v auf (dva * dva).summe() * (1.0 / 10)
    v.rueckwaerts()
    gradienten_kappen(params_enc, 1.0)
    opt_a.schritt()
    wenn s % 150 == 149:
        zeige "  A s=" + text(s) + " loss=" + text(v.zu_liste()[0])
    setze s auf s + 1

# GATE A: Retrieval accuracy@1 auf den Jitter-Holdout-Signalen
autograd_aus()
setze enc_jit auf encoder_batch(jit_px)
setze treffer auf 0
setze i auf 0
solange i < länge(jit_px):
    setze zeile auf enc_jit.zeilen(i, i + 1)
    setze best auf 0 - 1
    setze best_w auf 0 - 1000000000
    setze kk auf 0
    solange kk < 12:
        setze w auf kosinus(zeile, proto_zeile(kk)).zu_liste()[0]
        wenn w > best_w:
            setze best_w auf w
            setze best auf kk
        setze kk auf kk + 1
    wenn best == jit_kl[i]:
        setze treffer auf treffer + 1
    sonst:
        zeige "  A-FEHLER i=" + text(i) + " soll=" + text(jit_kl[i]) + " ist=" + text(best) + " w=" + text(best_w)
    setze i auf i + 1
setze acc_a auf treffer / länge(jit_px)
autograd_an()
setze gate_a auf acc_a >= 0.95
zeige "V3B-GATE-A retrieval@1=" + text(acc_a) + " -> " + text(gate_a)

# DEBUG: Retrieval auf Kombi-Holdout — generalisiert der Encoder-Raum?
autograd_aus()
setze enc_c auf encoder_batch(combo_px)
setze ctreffer auf 0
setze i auf 0
solange i < länge(combo_px):
    setze zeile auf enc_c.zeilen(i, i + 1)
    setze best auf 0 - 1
    setze best_w auf 0 - 1000000000
    setze kk auf 0
    solange kk < 12:
        setze w auf kosinus(zeile, proto_zeile(kk)).zu_liste()[0]
        wenn w > best_w:
            setze best_w auf w
            setze best auf kk
        setze kk auf kk + 1
    wenn best == combo_kl[i]:
        setze ctreffer auf ctreffer + 1
    setze i auf i + 1
autograd_an()
zeige "  A-DEBUG combo-retrieval=" + text(ctreffer / länge(combo_px))

# Encoder ab jetzt FROZEN: Embeddings ohne Tape vorberechnen
autograd_aus()
setze e_train auf encoder_batch(train_px)
setze e_jit auf encoder_batch(jit_px)
setze e_combo auf encoder_batch(combo_px)
autograd_an()

# ------------------------------------------------------------
# 6. STUFE B0: Mini-LLM KONDITIONAL vortrainieren (Lehr-Slots,
#    3 disjunkte Subraeume + Rauschen — V3a-Learnings)
# ------------------------------------------------------------
zeige "Stufe B0: LLM-Vortraining mit Lehr-Slots (3600 Schritte) ..."
autograd_aus()
setze band_emb auf tensor_nullen([3, DIM])
setze bz auf tensor_zufall([3, DIM], 81)
setze i auf 0
solange i < 3:
    setze j auf 0
    solange j < 16:
        band_emb.wert_setzen([i, j], bz.wert([i, j]))
        setze j auf j + 1
    setze i auf i + 1
setze dauer_emb auf tensor_nullen([2, DIM])
setze dz auf tensor_zufall([2, DIM], 82)
setze i auf 0
solange i < 2:
    setze j auf 16
    solange j < 32:
        dauer_emb.wert_setzen([i, j], dz.wert([i, j]))
        setze j auf j + 1
    setze i auf i + 1
setze muster_emb auf tensor_nullen([2, DIM])
setze mz auf tensor_zufall([2, DIM], 83)
setze i auf 0
solange i < 2:
    setze j auf 32
    solange j < 48:
        muster_emb.wert_setzen([i, j], mz.wert([i, j]) * 1.5)
        setze j auf j + 1
    setze i auf i + 1
autograd_an()

funktion lehr_slot(knr):
    gib_zurück band_emb.zeilen(knr_b(knr), knr_b(knr) + 1) + dauer_emb.zeilen(knr_d(knr), knr_d(knr) + 1) + muster_emb.zeilen(knr_m(knr), knr_m(knr) + 1)

setze params_llm auf parameter(llm_schichten())
setze opt_b0 auf optimierer_sgd(params_llm, 0.05, 0.9)
setze s auf 0
solange s < 3600:
    wenn s == 1200:
        setze opt_b0 auf optimierer_sgd(params_llm, 0.015, 0.9)
    wenn s == 2400:
        setze opt_b0 auf optimierer_sgd(params_llm, 0.005, 0.9)
    setze idx auf s % länge(train_px)
    setze knr auf train_kl[idx]
    setze slot_j auf lehr_slot(knr) + tensor_zufall([1, DIM], 200 + s) * 0.03
    setze v auf seq_loss(slot_j, caption_ids(knr))
    v.rueckwaerts()
    gradienten_kappen(params_llm, 1.0)
    opt_b0.schritt()
    wenn s % 300 == 299:
        zeige "  B0 s=" + text(s) + " loss=" + text(v.zu_liste()[0])
    setze s auf s + 1
zeige "B0-Endverlust: " + text(seq_loss(lehr_slot(0), caption_ids(0)).zu_liste()[0])

# ------------------------------------------------------------
# 7. STUFE B: NUR die Projektion trainieren (CE + MSE-Anker)
# ------------------------------------------------------------
zeige "Stufe B: Projektion (4500 Schritte) ..."
setze params_proj auf parameter([M["proj"]])
setze opt_p auf optimierer_sgd(params_proj, 0.02, 0.9)
setze s auf 0
solange s < 4500:
    wenn s == 1500:
        setze opt_p auf optimierer_sgd(params_proj, 0.005, 0.9)
    wenn s == 3000:
        setze opt_p auf optimierer_sgd(params_proj, 0.002, 0.9)
    setze idx auf s % länge(train_px)
    setze knr auf train_kl[idx]
    setze e auf e_train.zeilen(idx, idx + 1)
    setze pe auf vorwaerts([M["proj"]], e)
    setze ce auf seq_loss(pe, caption_ids(knr))
    setze dv auf pe - lehr_slot(knr)
    setze v auf ce + (dv * dv).summe() * (1.0 / DIM)
    v.rueckwaerts()
    gradienten_kappen(params_proj, 1.0)
    opt_p.schritt()
    grads_loeschen(params_llm)
    wenn s % 600 == 599:
        zeige "  B s=" + text(s) + " loss=" + text(v.zu_liste()[0])
    setze s auf s + 1

# ------------------------------------------------------------
# 8. GATE 1: Greedy-Caption exakt (Jitter- und Kombi-Holdout)
# ------------------------------------------------------------
funktion greedy_slot(e_inj):
    setze ids auf []
    solange länge(ids) < T_TEXT:
        setze logits auf mm_logits(e_inj, ids)
        setze n auf länge(ids) + 1
        ids.hinzufügen(argmax(logits.zeilen(n - 1, n).zu_liste()))
    gib_zurück ids

funktion greedy_ids(e_konst):
    gib_zurück greedy_slot(vorwaerts([M["proj"]], e_konst))

funktion caption_acc(e_batch, klassen):
    setze ok auf 0
    setze i auf 0
    solange i < länge(klassen):
        setze knr auf klassen[i]
        setze soll auf caption_ids(knr)
        setze ist auf greedy_ids(e_batch.zeilen(i, i + 1))
        wenn ids_gleich(ist, soll):
            setze ok auf ok + 1
        sonst:
            zeige "  CAP-FEHLER ist='" + ids_zu_text(ist) + "' soll='" + ids_zu_text(soll) + "'"
        setze i auf i + 1
    gib_zurück ok / länge(klassen)

autograd_aus()
setze acc_jit auf caption_acc(e_jit, jit_kl)
setze acc_combo auf caption_acc(e_combo, combo_kl)
zeige "  B-DEBUG train0 ist='" + ids_zu_text(greedy_ids(e_train.zeilen(0, 1))) + "' soll='" + ids_zu_text(caption_ids(train_kl[0])) + "'"
zeige "  B-DEBUG combo0 ist='" + ids_zu_text(greedy_ids(e_combo.zeilen(0, 1))) + "' soll='" + ids_zu_text(caption_ids(combo_kl[0])) + "'"
zeige "  B-DEBUG lehrslot-combo ist='" + ids_zu_text(greedy_slot(lehr_slot(combo_kl[0]))) + "' (liest LLM ungesehene Slots?)"
autograd_an()
setze gate_1a auf acc_jit >= 0.9
setze gate_1b auf acc_combo >= 0.9
zeige "V3B-GATE-1A jitter-holdout-acc=" + text(acc_jit) + " -> " + text(gate_1a)
zeige "V3B-GATE-1B kombi-holdout-acc=" + text(acc_combo) + " -> " + text(gate_1b)

# ------------------------------------------------------------
# 9. GATE 2: FD-Gradcheck der Projektion (4 Koordinaten)
# ------------------------------------------------------------
setze e0 auf e_train.zeilen(0, 0 + 1)
setze ids0 auf caption_ids(train_kl[0])
grads_loeschen(params_proj)
grads_loeschen(params_llm)
setze v auf seq_loss(vorwaerts([M["proj"]], e0), ids0)
v.rueckwaerts()
setze pw auf params_proj[0]
setze g auf pw.gradient()
setze pform auf pw.form()
setze gate_2 auf wahr
autograd_aus()
setze t auf 0
solange t < 4:
    setze i auf rng() % pform[0]
    setze j auf rng() % pform[1]
    setze ana auf g.wert([i, j])
    setze w0 auf pw.wert([i, j])
    pw.wert_setzen([i, j], w0 + EPS_FD)
    setze lp auf seq_loss(vorwaerts([M["proj"]], e0), ids0).zu_liste()[0]
    pw.wert_setzen([i, j], w0 - EPS_FD)
    setze lm auf seq_loss(vorwaerts([M["proj"]], e0), ids0).zu_liste()[0]
    pw.wert_setzen([i, j], w0)
    setze fd auf (lp - lm) / (2 * EPS_FD)
    setze diff auf fd - ana
    wenn diff < 0:
        setze diff auf 0 - diff
    setze skala auf fd
    wenn skala < 0:
        setze skala auf 0 - skala
    setze askala auf ana
    wenn askala < 0:
        setze askala auf 0 - askala
    wenn diff > 0.05 * (skala + askala + 0.001):
        setze gate_2 auf falsch
        zeige "  FD-Abweichung [" + text(i) + "," + text(j) + "]: fd=" + text(fd) + " ana=" + text(ana)
    setze t auf t + 1
autograd_an()
grads_loeschen(params_proj)
grads_loeschen(params_llm)
zeige "V3B-GATE-2 fd-gradcheck -> " + text(gate_2)

# ------------------------------------------------------------
# 10. GATE 3: Checkpoint-Roundtrip bit-identisch
# ------------------------------------------------------------
setze cnetz auf ki_netz([M["f1"], M["p1"], M["f2"], M["p2"], M["pg"], M["fl"], M["ed"], M["f1o"], M["p1o"], M["po"], M["flo"], M["edo"], M["edm"], M["emb"], M["pos"], M["ln1"], M["att"], M["ln2"], M["ff1"], M["ff2"], M["lnf"], M["kopf"], M["proj"]])
autograd_aus()
# Batch-1-Forward wie nach dem Laden (Encoder-Forward ist batchgroessen-abhaengig)
setze e0_rt auf encoder_batch([train_px[0]])
setze loss_vor auf seq_loss(vorwaerts([M["proj"]], e0_rt), ids0).zu_liste()[0]
setze zustand auf {}
zustand["netz"] = cnetz
zustand["schritt"] = 1
checkpoint_speichern(zustand, "/tmp/v3b_ckpt.mook")
setze z2 auf checkpoint_laden("/tmp/v3b_ckpt.mook")
setze sch2 auf z2["netz"]["schichten"]
M["f1"] = sch2[0]
M["p1"] = sch2[1]
M["f2"] = sch2[2]
M["p2"] = sch2[3]
M["pg"] = sch2[4]
M["fl"] = sch2[5]
M["ed"] = sch2[6]
M["f1o"] = sch2[7]
M["p1o"] = sch2[8]
M["po"] = sch2[9]
M["flo"] = sch2[10]
M["edo"] = sch2[11]
M["edm"] = sch2[12]
M["emb"] = sch2[13]
M["pos"] = sch2[14]
M["ln1"] = sch2[15]
M["att"] = sch2[16]
M["ln2"] = sch2[17]
M["ff1"] = sch2[18]
M["ff2"] = sch2[19]
M["lnf"] = sch2[20]
M["kopf"] = sch2[21]
M["proj"] = sch2[22]
setze e0b auf encoder_batch([train_px[0]])
setze loss_nach auf seq_loss(vorwaerts([M["proj"]], e0b), ids0).zu_liste()[0]
autograd_an()
setze gate_3 auf loss_vor == loss_nach
zeige "V3B-GATE-3 roundtrip vor=" + text(loss_vor) + " nach=" + text(loss_nach) + " -> " + text(gate_3)

# ------------------------------------------------------------
# 11. SELFTEST
# ------------------------------------------------------------
wenn gate_a und gate_1a und gate_1b und gate_2 und gate_3:
    zeige "SELFTEST_RESULT: PASS ki_multimodal_audio"
sonst:
    zeige "SELFTEST_RESULT: FAIL ki_multimodal_audio"
