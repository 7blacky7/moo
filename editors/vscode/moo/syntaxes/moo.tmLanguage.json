{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "moo",
  "scopeName": "source.moos",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#fstrings" },
    { "include": "#numbers" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#keywords-operator" },
    { "include": "#constants" },
    { "include": "#builtins" },
    { "include": "#operators" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.moos",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.moos",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.moos",
              "match": "\\\\[nrt\\\\\"']"
            }
          ]
        },
        {
          "name": "string.quoted.single.moos",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.moos",
              "match": "\\\\[nrt\\\\\"']"
            }
          ]
        }
      ]
    },
    "fstrings": {
      "patterns": [
        {
          "name": "string.interpolated.moos",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.moos",
              "match": "\\\\[nrt\\\\\"']"
            },
            {
              "name": "meta.embedded.expression.moos",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "#numbers" },
                { "include": "#constants" },
                { "include": "#builtins" },
                { "include": "#identifiers" },
                { "include": "#operators" }
              ]
            }
          ]
        },
        {
          "name": "string.interpolated.moos",
          "begin": "f'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.moos",
              "match": "\\\\[nrt\\\\\"']"
            },
            {
              "name": "meta.embedded.expression.moos",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "#numbers" },
                { "include": "#constants" },
                { "include": "#identifiers" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.moos",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.moos",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        {
          "name": "keyword.control.moos",
          "match": "\\b(wenn|if|sonst|else|solange|while|fÃžr|for|in|prÃžfe|match|fall|case|standard|default|versuche|try|fange|catch|wirf|throw|stopp|break|weiter|continue|gib_zurÃžck|return|importiere|import|aus|from|exportiere|export|als|as|aufrÃĪumen|defer|garantiere|guard|von|wo|wÃĪhle|sortiere)\\b"
        }
      ]
    },
    "keywords-declaration": {
      "patterns": [
        {
          "name": "keyword.declaration.moos",
          "match": "\\b(setze|set|auf|to|funktion|func|klasse|class|daten|data|konstante|const|neu|new)\\b"
        }
      ]
    },
    "keywords-operator": {
      "patterns": [
        {
          "name": "keyword.operator.logical.moos",
          "match": "\\b(und|and|oder|or|nicht|not)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.moos",
          "match": "\\b(wahr|true|falsch|false)\\b"
        },
        {
          "name": "constant.language.null.moos",
          "match": "\\b(nichts|none)\\b"
        },
        {
          "name": "variable.language.this.moos",
          "match": "\\b(selbst|this)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.moos",
          "match": "\\b(zeige|show|typ_von|type_of|lÃĪnge|length|eingabe|input|text|zufall|random|abs|wurzel|sqrt|runden|round|boden|floor|decke|ceil|min|max|bereich|range)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.io.moos",
          "match": "\\b(datei_lesen|file_read|datei_schreiben|file_write|datei_anhÃĪngen|file_append|datei_zeilen|file_lines|datei_existiert|file_exists|datei_lÃķschen|file_delete)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.graphics.moos",
          "match": "\\b(fenster_erstelle|window_create|fenster_lÃķschen|window_clear|fenster_aktualisieren|window_update|fenster_offen|window_is_open|fenster_schliessen|window_close|zeichne_rechteck|draw_rect|zeichne_kreis|draw_circle|zeichne_linie|draw_line|zeichne_pixel|draw_pixel|taste_gedrÃžckt|key_pressed|maus_x|mouse_x|maus_y|mouse_y|maus_gedrÃžckt|mouse_pressed|warte|delay)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.3d.moos",
          "match": "\\b(raum_erstelle|space_create|raum_offen|space_is_open|raum_lÃķschen|space_clear|raum_aktualisieren|space_update|raum_schliessen|space_close|raum_perspektive|space_perspective|raum_kamera|space_camera|raum_rotiere|space_rotate|raum_verschiebe|space_translate|raum_push|space_push|raum_pop|space_pop|raum_wÃžrfel|space_cube|raum_kugel|space_sphere|raum_dreieck|space_triangle)\\b(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.moos",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.nullish.moos",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.optional-chain.moos",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.spread.moos",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.range.moos",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.power.moos",
          "match": "\\*\\*"
        },
        {
          "name": "keyword.operator.arrow.moos",
          "match": "=>"
        },
        {
          "name": "keyword.operator.comparison.moos",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.moos",
          "match": "\\+=|-=|="
        },
        {
          "name": "keyword.operator.arithmetic.moos",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.decorator.moos",
          "match": "@(?=[a-zA-Z_])"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.moos",
          "match": "\\b([a-zA-Z_ÃĪÃķÃžÃÃÃÃ][a-zA-Z0-9_ÃĪÃķÃžÃÃÃÃ]*)\\b(?=\\s*\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.moos",
          "match": "\\b[a-zA-Z_ÃĪÃķÃžÃÃÃÃ][a-zA-Z0-9_ÃĪÃķÃžÃÃÃÃ]*\\b"
        }
      ]
    }
  }
}
