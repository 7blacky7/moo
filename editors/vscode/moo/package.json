{
  "name": "moo-lang",
  "displayName": "moo Language",
  "description": "Syntax-Highlighting für die zweisprachige Programmiersprache moo",
  "version": "0.1.0",
  "publisher": "moo-lang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "moo",
        "aliases": ["moo", "Moo"],
        "extensions": [".moo"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "moo",
        "scopeName": "source.moo",
        "path": "./syntaxes/moo.tmLanguage.json"
      }
    ]
  }
}
