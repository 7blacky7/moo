{
  "name": "moo-lang",
  "displayName": "moo Language",
  "description": "Syntax-Highlighting und LSP für die mehrsprachige Programmiersprache moo",
  "version": "0.2.0",
  "publisher": "moo-lang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:moo"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "moo",
        "aliases": [
          "moo",
          "Moo"
        ],
        "extensions": [
          ".moo"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "moo",
        "scopeName": "source.moo",
        "path": "./syntaxes/moo.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
